{
  "name": "sintraclassicos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate-config": "node scripts/generate-config.js",
    "update-galeria-index": "node scripts/update-galeria-index.js",
    "reorganize-galeria": "node scripts/reorganize-galeria-orders.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "build": "npm run generate-config && npm run reorganize-galeria && npm run update-galeria-index && node build.js && npm run generate-sitemap",
    "dev": "npm run build && npx serve dist -p 8888",
    "serve": "npx serve dist",
    "netlify:dev": "netlify dev",
    "cms:proxy": "npx netlify-cms-proxy-server"
  },
  "devDependencies": {
    "netlify-cli": "^17.0.0",
    "netlify-cms-proxy-server": "^1.3.0"
  }
}
